POSTGRES_DB=bff_rag
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-local-postgres-password

DATABASE_URL=postgresql+asyncpg://admin:change-me-local-postgres-password@postgres:5432/bff_rag
REDIS_URL=redis://redis:6379
OLLAMA_URL=http://ollama:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3.1:8b
FAST_LLM_MODEL=
LLM_TIMEOUT_SECONDS=120
LLM_NUM_PREDICT=256
LLM_TEMPERATURE=0.2
LLM_KEEP_ALIVE=10m
EMBED_DIMS=768
CACHE_THRESHOLD=0.92
CACHE_TTL=3600
CACHE_LOOKUP_MAX_CANDIDATES=25
TOP_K_RETRIEVE=8
TOP_K_RERANK=3
RERANK_DIRECT_HIT_THRESHOLD=0.85
QUERY_HISTORY_LIMIT=4
QUERY_MAX_CONTEXT_TOKENS=1024
QUERY_MAX_HISTORY_TOKENS=256
QUERY_MAX_CONTEXT_CHARS=2400
QUERY_MAX_HISTORY_CHARS=800
RERANK_MIN_CANDIDATES=5
EMBED_BATCH_SIZE=16
INGEST_JOB_TTL=3600

RAG_SERVICE_URL=http://rag-service:8000
JWT_SECRET=change-me-local-dev-jwt-secret
NODE_ENV=development
HTTP_BODY_LIMIT=10mb
FRONTEND_ORIGIN=http://localhost:3001
QUERY_RATE_LIMIT_MAX=30
QUERY_RATE_LIMIT_WINDOW_MS=60000
STREAM_RATE_LIMIT_MAX=10
STREAM_RATE_LIMIT_WINDOW_MS=60000
HISTORY_RATE_LIMIT_MAX=30
HISTORY_RATE_LIMIT_WINDOW_MS=60000
ADMIN_RATE_LIMIT_MAX=20
ADMIN_RATE_LIMIT_WINDOW_MS=60000

NEXT_PUBLIC_BFF_URL=http://localhost:3000

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-grafana-password
GRAFANA_DEFAULT_THEME=dark
